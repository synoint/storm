<p>
    {{ question.text }}
</p>

<table class="table table-borderless table-hover">
    <thead>
        <tr>
            <td>&nbsp;</td>
            {% for column in question.getColumns() %}
            <th scope="col">
                {{ column }}
            </th>
            {% endfor %}
        </tr>
    </thead>
    <tbody>
        {% for rowCode,rowLabel in question.getRows() %}
            <tr>
                <th scope="row">{{ rowLabel }}</th>
                {% for child in attribute(form, (rowCode)) %}
                    <td>
                    <div class="custom-control {{ (question.questionTypeId  is same as(3)) ? 'custom-radio"' : 'custom-checkbox' }}"> 
                        {{ form_widget(child, {'label' : false, 'label_attr': {'class': 'custom-control-label'}}) }}
                    </div>
                    </td>
                {% endfor %}
            </tr>
        {% endfor %}
    </tbody>
</table>